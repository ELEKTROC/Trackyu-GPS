{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "types": ["vite/client"]
  },
  "include": [
    "index.tsx",
    "App.tsx",
    "LazyViews.tsx",
    "types.ts",
    "constants.ts",
    "setupTests.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "contexts",
    "components",
    "features",
    "hooks",
    "lib",
    "schemas",
    "services",
    "utils",
    "tests"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "backend",
    "android",
    "trackyu-mobile-expo",
    "Archives",
    "monitoring",
    "mosquitto",
    "website",
    "scripts"
  ]
}
