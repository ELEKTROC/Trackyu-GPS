*_secret.txt
*.pem
*.key

# Temporary files
temp_*.sql
temp_*.csv
temp_*.txt
test_output*.txt
*.tmp

# Generated documents (never commit binary outputs)
*.pdf
*.xlsx
*.xls
tsc_output.txt

# Deploy packages (regenerated by prepare_deploy.ps1)
deploy_package/
deploy_*.zip

# Archives - Old/obsolete files (do not include in build or commits)
Archives/

# Database backups (contain production data)
backups/
*.sql.gz

# Mobile app — repo dédié depuis 2026-04-28 (github.com/ELEKTROC/trackyu-mobile)
