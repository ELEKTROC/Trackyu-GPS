# Lint-staged (ESLint + Prettier on staged files)
echo "🔍 Running lint-staged..."
npx lint-staged
if [ $? -ne 0 ]; then
  echo "❌ Lint-staged failed. Fix lint/format errors before committing."
  exit 1
fi

# TypeScript type-check (frontend)
echo "🔍 Type-checking frontend..."
npx tsc --noEmit --pretty 2>&1 | head -20
if [ $? -ne 0 ]; then
  echo "❌ Frontend type-check failed. Fix errors before committing."
  exit 1
fi

# TypeScript type-check (backend)
echo "🔍 Type-checking backend..."
cd backend && npx tsc --noEmit --pretty 2>&1 | head -20
if [ $? -ne 0 ]; then
  echo "❌ Backend type-check failed. Fix errors before committing."
  exit 1
fi
cd ..

# Secrets scan - block commits with hardcoded secrets
echo "🔐 Scanning for secrets..."
SECRETS_FOUND=$(git diff --cached --diff-filter=ACMR | grep -iE "\b(password|secret|api_key|token|private_key)\b\s*[:=]\s*['\"][^'\"]{8,}" | grep -v "\.env" | grep -v "test" | grep -v "mock" | grep -v "example" | grep -v "plainPassword" || true)
if [ -n "$SECRETS_FOUND" ]; then
  echo "❌ Potential secrets found in staged files:"
  echo "$SECRETS_FOUND"
  echo "Remove secrets and use environment variables instead."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
